# Copy to ".env" and fill in. docker compose reads this automatically.

# Your own Signal number in international format (the one you link the API to).
SIGNAL_NUMBER=+3585012345678

# The ONE target Signal group id, WITH the "group." prefix.
# Get it from:  curl http://127.0.0.1:8080/v1/groups/$SIGNAL_NUMBER
SIGNAL_GROUP_ID=group.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX=

# WhatsApp groups to mirror into that one Signal group. Comma-separated.
# Each entry is "JID" or "JID=Label". The label is prefixed to every mirrored
# message so you can tell the two feeds apart in Signal, e.g. "[Admins] ...".
# If you omit "=Label", the WhatsApp group's own name is used as the label.
# Leave blank on first run — the relay logs all your groups' JIDs so you can copy them.
WA_GROUPS=120363000000000001@g.us=Tiedoitus,120363000000000002@g.us=Yleinen

# Show the [Label] prefix on mirrored messages? Recommended when mirroring 2+ groups.
SHOW_GROUP_LABEL=true

# Mirror your OWN WhatsApp messages too? true = full mirror, false = skip your own.
RELAY_FROM_ME=true

# Display name used for your own outgoing WhatsApp messages (when RELAY_FROM_ME=true).
WA_SELF_NAME=Me

# baileys/relay log level: trace | debug | info | warn | error
LOG_LEVEL=info
